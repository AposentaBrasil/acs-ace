<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulador de Aposentadoria PEC 14/2021</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    :root {
        --original-blue: #1e3a8a;
        --original-bg: #eef2f6;
        --original-border: #d1d9e6;
        --accent-orange: #f97316;
        --whatsapp-green: #25d366;
        --insta-gradient: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
        --white: #ffffff;
    }

    *{box-sizing:border-box; scroll-behavior: smooth;}
    body{margin:0;font-family:'Inter', sans-serif;background:var(--original-bg);color:#0f172a;}
    .app{max-width:420px;margin:auto;padding:14px;display:flex;flex-direction:column;gap:12px;padding-bottom: 50px;}

    .card{background:var(--white); border:1px solid var(--original-border); border-radius:12px; padding:18px;}
    h1{font-size:16px; margin:0; font-weight:600; color: var(--original-blue);}
    .sub{font-size:12px; color:#475569;}
    .label{font-size:12px; font-weight:600; margin-bottom:8px; display:block;}

    .social-proof { font-size: 11px; color: #1e293b; margin-bottom: 5px; display: flex; align-items: center; gap: 5px; justify-content: center; background: #dcfce7; padding: 8px; border-radius: 20px; font-weight: 500; }

    #loading-container { display: none; margin-top: 20px; text-align: center; background: #f1f5f9; padding: 15px; border-radius: 10px; border: 1px solid var(--original-border); }
    .loading-text { font-size: 11px; font-weight: 800; color: var(--original-blue); margin-bottom: 10px; min-height: 14px; text-transform: uppercase; }
    
    .progress-bar-bg { width: 100%; height: 12px; background: #e2e8f0; border-radius: 10px; overflow: hidden; border: 1px solid var(--original-border); }
    .progress-bar-fill { width: 0%; height: 100%; background: linear-gradient(90deg, var(--original-blue), var(--accent-orange)); transition: width 0.3s ease; }

    .sex{display:flex; gap:6px; margin-bottom: 10px;}
    .sex button{flex:1; padding:10px; border-radius:6px; border:1px solid #cbd5e1; background:#f8fafc; font-size:13px; cursor:pointer;}
    .sex button.active{background:var(--original-blue); color:var(--white); border-color:var(--original-blue);}

    .row{display:flex; align-items:center; gap:8px; margin-bottom:4px;}
    .year, .day{font-size:20px; font-weight:600; width:60px; color:var(--original-blue);}
    .btn-step{ width:36px; height:36px; border-radius:50%; border:1px solid #cbd5e1; background:#fff; color:var(--original-blue); font-weight:bold; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center; }

    input[type=range]{flex:1; height:4px; appearance:none; background:#cbd5e1; border-radius:4px;}
    input[type=range]::-webkit-slider-thumb{appearance:none; width:18px; height:18px; background:var(--original-blue); border-radius:50%; border:2px solid #fff;}

    /* GRID DOS MESES - RESTAURADO */
    .months{display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; margin: 10px 0;}
    .months button{ padding: 8px 0; font-size: 10px; border-radius: 4px; border: 1px solid #cbd5e1; background: #f8fafc; cursor: pointer; }
    .months button.active{background:var(--original-blue); color:var(--white); border-color: var(--original-blue);}

    .calc{width:100%; padding:16px; border-radius:8px; background:var(--original-blue); color:var(--white); font-size:15px; font-weight:700; border:none; cursor:pointer; margin-top:5px;}

    .result-section { display: none; margin-top: 15px; animation: slideIn 0.5s ease-out; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .res-card-main { text-align:center; border-top: 6px solid var(--original-blue); border-radius: 16px; background: var(--white); padding: 20px; border: 1px solid var(--original-border); margin-bottom: 12px;}
    .data-destaque { font-size: 32px; font-weight: 900; color: var(--original-blue); display: block; margin: 8px 0; }

    /* Box de E-mail Verde */
    .unlock-overlay { background: var(--white); border: 2px dashed var(--whatsapp-green); border-radius: 16px; padding: 24px; text-align: center; margin-top: 15px; }
    input[type=email] { width: 100%; padding: 16px; border-radius: 12px; border: 2px dashed var(--whatsapp-green); font-size: 16px; margin-bottom: 12px; outline: none; background: #f0fdf4; }
    .btn-enviar { width: 100%; padding: 18px; background: var(--whatsapp-green); color: var(--white); border: none; border-radius: 12px; font-weight: 800; font-size: 16px; cursor: pointer; }

    .blur-wrapper { position: relative; border-radius: 12px; overflow: hidden; }
    .blur-box { filter: blur(6px); opacity: 0.5; pointer-events: none; transition: 0.5s; }
    .unlocked .blur-box { filter: none; opacity: 1; pointer-events: auto; }
    .lock-shield { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 5; }
    .lock-tag { background: var(--original-blue); color: white; padding: 6px 12px; border-radius: 20px; font-size: 10px; font-weight: 800; }
    .unlocked .lock-shield { display: none; }

    /* Instagram Box */
    .insta-premium-box { display: none; margin-top: 20px; padding: 2px; background: var(--insta-gradient); border-radius: 16px; }
    .insta-premium-content { background: var(--white); padding: 20px; border-radius: 14px; text-align: center; }
    .insta-avatar { width: 60px; height: 60px; border-radius: 50%; border: 2px solid #e6683c; padding: 2px; margin-bottom: 10px; }
    .btn-insta-final { display: inline-flex; align-items: center; justify-content: center; padding: 12px 24px; background: var(--insta-gradient); color: white; text-decoration: none; border-radius: 10px; font-weight: 800; font-size: 14px; margin-top: 10px; }
    
    .btn-share { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 16px; background: var(--whatsapp-green); color: white; border-radius: 10px; font-weight: 800; font-size: 14px; margin-top: 15px; border: none; cursor: pointer; text-decoration: none; }
</style>
</head>
<body>

<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>

<div class="app">
    <div class="card">
        <h1>Simulador de Aposentadoria PEC 14/2021</h1>
        <div class="sub">Simulador de Aposentadoria para ACS e ACE</div>
    </div>

    <div class="social-proof">
        <span>⚡</span> 1.248 servidores auditaram seus dados hoje.
    </div>

    <div id="card-dados" class="card">
        <span class="label">Gênero</span>
        <div class="sex">
            <button id="btnM" class="active" onclick="setS('m')">Masculino</button>
            <button id="btnF" onclick="setS('f')">Feminino</button>
        </div>

        <span class="label">Nascimento</span>
        <div class="row">
            <div class="day" id="valDiaN">05</div>
            <div class="btn-step" onclick="step('rangeDiaN', -1)">−</div>
            <input type="range" min="1" max="31" value="5" id="rangeDiaN" oninput="upd()">
            <div class="btn-step" onclick="step('rangeDiaN', 1)">+</div>
        </div>
        <div id="mesNBox" class="months"></div>
        <div class="row">
            <div class="year" id="valAnoN">1978</div>
            <div class="btn-step" onclick="step('rangeAnoN', -1)">−</div>
            <input type="range" min="1945" max="2005" value="1978" id="rangeAnoN" oninput="upd()">
            <div class="btn-step" onclick="step('rangeAnoN', 1)">+</div>
        </div>

        <span class="label" style="margin-top:15px">Início no Serviço Público (ACS/ACE)</span>
        <div class="row">
            <div class="day" id="valDiaE">23</div>
            <div class="btn-step" onclick="step('rangeDiaE', -1)">−</div>
            <input type="range" min="1" max="31" value="23" id="rangeDiaE" oninput="upd()">
            <div class="btn-step" onclick="step('rangeDiaE', 1)">+</div>
        </div>
        <div id="mesEBox" class="months"></div>
        <div class="row">
            <div class="year" id="valAnoE">2002</div>
            <div class="btn-step" onclick="step('rangeAnoE', -1)">−</div>
            <input type="range" min="1975" max="2024" value="2002" id="rangeAnoE" oninput="upd()">
            <div class="btn-step" onclick="step('rangeAnoE', 1)">+</div>
        </div>
        
        <button class="calc" id="btn-gerar" onclick="iniciarFluxo()">CALCULAR APOSENTADORIA</button>

        <div id="loading-container">
            <div id="loading-msg" class="loading-text">Iniciando...</div>
            <div class="progress-bar-bg"><div id="loading-bar" class="progress-bar-fill"></div></div>
        </div>
    </div>

    <div id="secao-resultado" class="result-section">
        <div class="res-card-main">
            <span class="label">Sua Aposentadoria prevista:</span>
            <span class="data-destaque" id="data-final-txt">--/--/----</span>
        </div>

        <div class="blur-wrapper" id="blur-wrapper">
            <div class="lock-shield"><div class="lock-tag">🔒 RELATÓRIO COMPLETO BLOQUEADO</div></div>
            <div class="card blur-box">
                <div style="font-size:13px; line-height: 1.8; font-weight: 700;">
                    • Idade na Data: <span id="res-idade">--</span><br>
                    • Tempo de Contribuição: <span id="res-tempo">--</span><br>
                    • Bônus Redutor: <span id="res-red">--</span><br>
                    <div style="background:#fff7ed; padding:12px; border-radius:10px; border: 1px solid #fed7aa; margin-top:10px;">
                        <span style="font-size: 10px; color: #c2410c; display: block; font-weight: 800;">TEMPO RESTANTE:</span>
                        <span id="res-falta-detalhado" style="color:var(--accent-orange); font-size:14px;">--</span>
                    </div>
                </div>
            </div>
        </div>

        <div id="overlay-email" class="unlock-overlay">
            <h3 style="font-size: 16px; margin: 0 0 8px 0; color: var(--original-blue);">Relatório Pronto!</h3>
            <p style="font-size:13px; color:#64748b; margin-bottom:18px;">Informe seu e-mail para liberar o relatório completo:</p>
            
            <form id="mc-form" action="COLE_URL_AQUI" method="POST" target="hidden_iframe">
                <input type="email" name="EMAIL" id="inputEmail" placeholder="seu@email.com" required>
                <button type="submit" class="btn-enviar" onclick="validarERevelar(event)">DESBLOQUEAR AGORA</button>
            </form>
        </div>

        <div id="insta-premium" class="insta-premium-box">
            <div class="insta-premium-content">
                <img src="https://github.com/aciolete.png" class="insta-avatar" alt="Avatar">
                <div style="font-size:15px; font-weight:800; color:#1e293b;">Siga para mais atualizações!</div>
                <a href="https://www.instagram.com/aciolete/" target="_blank" class="btn-insta-final">SEGUIR NO INSTAGRAM</a>
            </div>
        </div>

        <button onclick="compartilharWhatsApp()" class="btn-share">COMPARTILHAR NO WHATSAPP</button>
    </div>
</div>

<script>
const mesesNomes = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
let config = { s: 'm', mN: 0, mE: 11 };

function setS(val) { 
    config.s = val; 
    document.getElementById('btnM').className = val === 'm' ? 'active' : ''; 
    document.getElementById('btnF').className = val === 'f' ? 'active' : ''; 
}

function upd() {
    document.getElementById('valAnoN').innerText = document.getElementById('rangeAnoN').value;
    document.getElementById('valAnoE').innerText = document.getElementById('rangeAnoE').value;
    document.getElementById('valDiaN').innerText = document.getElementById('rangeDiaN').value.padStart(2, '0');
    document.getElementById('valDiaE').innerText = document.getElementById('rangeDiaE').value.padStart(2, '0');
}

function step(id, val) {
    const el = document.getElementById(id);
    let nv = parseInt(el.value) + val;
    if (nv >= el.min && nv <= el.max) el.value = nv;
    upd();
}

function renderMeses(id, key) {
    const box = document.getElementById(id); 
    box.innerHTML = '';
    mesesNomes.forEach((m, i) => {
        const btn = document.createElement('button');
        btn.innerText = m;
        if (i === config[key]) btn.className = 'active';
        btn.onclick = () => { 
            config[key] = i; 
            renderMeses(id, key); 
            upd(); 
        };
        box.appendChild(btn);
    });
}

function iniciarFluxo() {
    const btn = document.getElementById('btn-gerar');
    const loader = document.getElementById('loading-container');
    const bar = document.getElementById('loading-bar');
    const msg = document.getElementById('loading-msg');
    btn.disabled = true; 
    loader.style.display = 'block';

    let prog = 0;
    const etapas = [
        {p: 10, m: "Cruzando Dados com a PEC 14..."}, 
        {p: 40, m: "Consultando Base de Dados..."}, 
        {p: 70, m: "Validando Requisitos..."}, 
        {p: 90, m: "Cálculo Finalizado"}
    ];

    const interval = setInterval(() => {
        prog++; 
        bar.style.width = prog + "%";
        const etapa = etapas.find(e => prog === e.p);
        if (etapa) msg.innerText = etapa.m;
        if(prog >= 100) { 
            clearInterval(interval); 
            exibirResultado(); 
        }
    }, 30);
}

function exibirResultado() {
    const dN = new Date(document.getElementById('rangeAnoN').value, config.mN, document.getElementById('rangeDiaN').value, 12);
    const dE = new Date(document.getElementById('rangeAnoE').value, config.mE, document.getElementById('rangeDiaE').value, 12);
    let dSim = new Date(); 
    dSim.setHours(12, 0, 0, 0);
    let dataFinal = null;

    while (!dataFinal) {
        let ano = dSim.getFullYear();
        let idade = getAnosCompletos(dN, dSim);
        let tempo = getAnosCompletos(dE, dSim);
        let red = Math.min(Math.max(tempo - 25, 0), 5);
        let base = (config.s === 'm') ? (ano <= 2030 ? 52 : 54) : (ano <= 2030 ? 50 : 52);
        
        if (idade >= (base - red) && tempo >= 25) {
            dataFinal = new Date(dSim);
        } else {
            dSim.setDate(dSim.getDate() + 1);
        }
    }

    document.getElementById('data-final-txt').innerText = dataFinal.toLocaleDateString('pt-BR');
    
    window.dadosCalculados = {
        idade: getAnosCompletos(dN, dataFinal),
        tempo: getAnosCompletos(dE, dataFinal),
        red: Math.min(Math.max(getAnosCompletos(dE, dataFinal) - 25, 0), 5),
        contagem: getContagemRegressiva(dataFinal)
    };

    document.getElementById('secao-resultado').style.display = 'block';
    setTimeout(() => { document.getElementById('secao-resultado').scrollIntoView({ behavior: 'smooth' }); }, 100);
}

function getContagemRegressiva(df) {
    const hoje = new Date(); 
    hoje.setHours(12, 0, 0, 0);
    const alvo = new Date(df); 
    alvo.setHours(12, 0, 0, 0);
    if (alvo <= hoje) return "Requisito já cumprido!";

    let anos = alvo.getFullYear() - hoje.getFullYear();
    let meses = alvo.getMonth() - hoje.getMonth();
    let dias = alvo.getDate() - hoje.getDate();

    if (dias < 0) {
        meses--;
        dias += new Date(alvo.getFullYear(), alvo.getMonth(), 0).getDate();
    }
    if (meses < 0) {
        anos--;
        meses += 12;
    }

    let p = [];
    if (anos > 0) p.push(anos + (anos === 1 ? " ano" : " anos"));
    if (meses > 0) p.push(meses + (meses === 1 ? " mês" : " meses"));
    if (dias > 0) p.push(dias + (dias === 1 ? " dia" : " dias"));
    
    if (p.length === 0) return "Menos de 1 dia";
    const last = p.pop();
    return p.length ? p.join(", ") + " e " + last : last;
}

function getAnosCompletos(i, f) {
    let a = f.getFullYear() - i.getFullYear();
    if (f.getMonth() < i.getMonth() || (f.getMonth() === i.getMonth() && f.getDate() < i.getDate())) a--;
    return a;
}

function validarERevelar(event) {
    const email = document.getElementById('inputEmail').value;
    if (email.includes('@') && email.includes('.')) {
        const d = window.dadosCalculados;
        document.getElementById('res-idade').innerText = `${d.idade} anos`;
        document.getElementById('res-tempo').innerText = `${d.tempo} anos`;
        document.getElementById('res-red').innerText = `${d.red} anos`;
        document.getElementById('res-falta-detalhado').innerText = d.contagem;

        document.getElementById('overlay-email').style.display = 'none';
        document.getElementById('blur-wrapper').classList.add('unlocked');
        document.getElementById('insta-premium').style.display = 'block';
    } else { 
        alert("Informe um e-mail válido."); 
        event.preventDefault();
    }
}

function compartilharWhatsApp() {
    const url = window.location.href;
    const msg = encodeURIComponent("*Simulador Oficial PEC 14/2021*\nAcabei de ver minha data de aposentadoria diferenciada. Veja a sua também:\n\n" + url);
    window.open(`https://api.whatsapp.com/send?text=${msg}`, '_blank');
}

renderMeses('mesNBox', 'mN'); 
renderMeses('mesEBox', 'mE'); 
upd();
</script>
</body>
</html>
